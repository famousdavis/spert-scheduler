rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // ── Projects ──
    match /spertscheduler_projects/{projectId} {
      allow list: if isAuth() &&
        request.auth.uid in resource.data.members;

      allow get: if isAuth() && request.auth.uid in resource.data.members;

      allow create: if isAuth() && request.resource.data.members[request.auth.uid] == 'owner';

      // Update: editors can update, but only owners can change owner/members.
      // This prevents privilege escalation by editors.
      allow update: if isAuth()
                    && (resource.data.members[request.auth.uid] == 'owner' || resource.data.members[request.auth.uid] == 'editor')
                    && (
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['owner', 'members']))
                      || resource.data.members[request.auth.uid] == 'owner'
                    );

      allow delete: if isAuth() && resource.data.members[request.auth.uid] == 'owner';
    }

    // ── User profiles ──
    // Profiles must be readable by all authenticated users to support
    // email-based member lookup in the sharing UI.
    match /spertscheduler_profiles/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── User settings ──
    match /spertscheduler_settings/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth() && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly([
                        'defaultTrialCount', 'defaultDistributionType', 'defaultConfidenceLevel',
                        'defaultActivityTarget', 'defaultProjectTarget', 'dateFormat',
                        'autoRunSimulation', 'theme', 'storeFullSimulationData',
                        'defaultHeuristicEnabled', 'defaultHeuristicMinPercent', 'defaultHeuristicMaxPercent',
                        'defaultDependencyMode', 'defaultParkinsonsLawEnabled',
                        'globalCalendar', 'ganttViewMode', 'ganttShowToday',
                        'ganttShowCriticalPath', 'ganttShowProjectName', 'ganttShowArrows',
                        'defaultHolidayCountry', 'workDays',
                        'targetFinishGreenPct', 'targetFinishAmberPct',
                        'suppressLocalStorageWarning'
                      ]);
    }

    // ── ToS acceptance records (shared across all SPERT apps) ──
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAuth() && request.auth.uid == uid
                   && request.resource.data.keys().hasOnly([
                        'acceptedAt', 'tosVersion', 'privacyPolicyVersion', 'appId', 'authProvider'
                      ]);
    }
  }
}
