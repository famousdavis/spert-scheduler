# Firebase configuration for cloud storage.
# When these are empty/missing, the app operates in local-only mode.
# Copy this file to .env.local and fill in values from Firebase Console.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=spert-suite
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
